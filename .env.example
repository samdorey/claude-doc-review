# Copy to ".env" (same folder as gdocs_review.py) and fill in.
# The script loads this automatically; .env is git-ignored so your key stays local.

# Required for `run` / `auto` (Claude-generated rewrites).
# Get one from the Anthropic Console: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the default model (claude-opus-4-8).
# ANTHROPIC_MODEL=claude-sonnet-4-6
